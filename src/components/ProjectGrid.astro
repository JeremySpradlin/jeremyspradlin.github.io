---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../utils/paths";

type Props = {
  projects: CollectionEntry<"projects">[];
};

const { projects } = Astro.props;
---

<div class="project-grid">
  {
    projects.map((project) => (
      <article class="project-card">
        <img
          src={withBase(project.data.image)}
          alt={`${project.data.title} preview`}
          loading="lazy"
        />
        <div class="project-card-body">
          <div class="project-card-meta">
            <span class="project-status">{project.data.status}</span>
          </div>
          <h3>{project.data.title}</h3>
          <p>{project.data.description}</p>
          {project.data.tech.length > 0 && (
            <ul class="project-tech-list" aria-label={`${project.data.title} technologies`}>
              {project.data.tech.map((item) => (
                <li class="project-tech-tag">{item}</li>
              ))}
            </ul>
          )}
          <a class="text-link" href={project.data.githubUrl} target="_blank" rel="noreferrer">
            View on GitHub
          </a>
        </div>
      </article>
    ))
  }
</div>
