---
import { siteConfig } from "../config/site";
import { withBase } from "../utils/paths";

const normalizedPath = (() => {
  const base = import.meta.env.BASE_URL;
  const path = Astro.url.pathname.startsWith(base)
    ? Astro.url.pathname.slice(base.length - 1)
    : Astro.url.pathname;

  return path.endsWith("/") ? path : `${path}/`;
})();
---

<header class="site-header">
  <a class="brand" href={withBase("/")}>
    <span class="brand-mark"></span>
    <span>
      <strong>{siteConfig.siteTitle}</strong>
      <small>{siteConfig.authorName}</small>
    </span>
  </a>

  <nav class="site-nav" aria-label="Primary">
    {
      siteConfig.navigation.map((item) => (
        <a href={withBase(item.href)} class={normalizedPath === item.href ? "active" : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
