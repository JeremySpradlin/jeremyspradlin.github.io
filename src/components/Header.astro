---
import { siteConfig } from "../config/site";
import { withBase } from "../utils/paths";

type Props = {
  backHref?: string;
};

const { backHref } = Astro.props;

const normalizedPath = (() => {
  const base = import.meta.env.BASE_URL;
  const path = Astro.url.pathname.startsWith(base)
    ? Astro.url.pathname.slice(base.length - 1)
    : Astro.url.pathname;

  return path.endsWith("/") ? path : `${path}/`;
})();
---

<header class="site-header">
  <div class="header-brand-group">
    {backHref && (
      <a class="header-back-link" href={withBase(backHref)} aria-label="Back to blog">
        ←
      </a>
    )}

    <a class="brand" href={withBase("/")}>
      <span class="brand-mark"></span>
      <span>
        <strong>{siteConfig.siteTitle}</strong>
        <small>{siteConfig.authorName}</small>
      </span>
    </a>
  </div>

  <nav class="site-nav" aria-label="Primary">
    {
      siteConfig.navigation.map((item) => (
        <a href={withBase(item.href)} class={normalizedPath === item.href ? "active" : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
