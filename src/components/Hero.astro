---
import type { CollectionEntry } from "astro:content";
import { siteConfig } from "../config/site";
import { withBase } from "../utils/paths";

type Props = {
  heroContent: CollectionEntry<"home">;
};

const { heroContent } = Astro.props;
---

<section class="hero">
  <div class="hero-copy">
    <div class="hero-main">
      <p class="eyebrow">{heroContent.data.roleLine}</p>
      <h1 class="hero-site-title">{siteConfig.siteTitle}</h1>
      <p class="hero-name">{heroContent.data.greeting}</p>
      <p class="hero-tagline">{heroContent.data.tagline}</p>
      <div class="hero-actions">
        <a class="button button-primary" href={withBase("/blog/")}>Read the Blog</a>
        <a class="button" href={withBase("/projects/")}>View Projects</a>
        <a class="button" href={withBase("/resume/")}>Resume</a>
      </div>
    </div>

    <div class="hero-side">
      <div class="hero-focus">
        <p class="hero-card-label">{heroContent.data.focusTitle}</p>
        <div class="hero-focus-list">
          {
            heroContent.data.focusItems.map((item, index) => (
              <div class:list={["hero-focus-item", index === 0 && "hero-focus-item-featured"]}>
                <span class="hero-focus-dot"></span>
                <p>{item}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
