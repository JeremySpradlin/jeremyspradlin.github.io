---
import { getCollection } from "astro:content";
import BlogSearch from "../../components/BlogSearch.astro";
import PostList from "../../components/PostList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Blog" description="Writing on data science, software, and practical technical work.">
  <section class="section blog-archive">
    <div class="blog-archive-header">
      <div class="page-intro blog-page-intro">
        <p class="eyebrow">Writing</p>
        <h1>Signal and Noise</h1>
        <p>
          A running set of notes on data science, software engineering, and the technical details worth
          slowing down to examine.
        </p>
      </div>

      <BlogSearch />
    </div>

    <PostList posts={posts} />
  </section>
</BaseLayout>
