---
import { getCollection } from "astro:content";
import Hero from "../components/Hero.astro";
import PostList from "../components/PostList.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import { projects } from "../data/projects";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featuredProjects = projects.filter((project) => project.featured).slice(0, 3);
---

<BaseLayout showHeader={false}>
  <Hero />

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Latest Posts</p>
        <h2>Recent Writing</h2>
      </div>
      <a class="text-link" href={withBase("/blog/")}>Browse all posts</a>
    </div>
    <PostList posts={posts} compact={true} />
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Featured Work</p>
        <h2>Projects</h2>
      </div>
      <a class="text-link" href={withBase("/projects/")}>View all projects</a>
    </div>
    <ProjectGrid projects={featuredProjects} />
  </section>

  <section class="section two-column">
    <div class="panel">
      <p class="eyebrow">Professional Snapshot</p>
      <h2>Experience</h2>
      <p>
        Data scientist and machine learning engineer with 20+ years spanning AI, signals
        intelligence, technical training, and mission-focused software delivery.
      </p>
      <ul class="highlight-list">
        <li>Production ML and computer vision pipelines across Kubernetes, Docker, and Azure</li>
        <li>Signals intelligence and ISR systems development, field testing, and operator training</li>
        <li>Technical instruction and writing that bridge expert and non-technical audiences</li>
      </ul>
    </div>

    <div class="panel accent-panel">
      <p class="eyebrow">Resume</p>
      <h2>Clearance, Writing, and Resume</h2>
      <p>
        Includes a concise professional summary, selected publications, training background, and
        direct access to the current PDF resume.
      </p>
      <a class="button button-primary" href={withBase("/resume/")}>Open Resume Page</a>
    </div>
  </section>
</BaseLayout>
