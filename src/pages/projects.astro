---
import { getCollection } from "astro:content";
import ProjectGrid from "../components/ProjectGrid.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = await getCollection("projects");
const sortedProjects = projects.sort(
  (a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title),
);
---

<BaseLayout title="Projects" description="Selected data science and software projects.">
  <section class="section page-intro">
    <p class="eyebrow">Selected Work</p>
    <h1>Projects</h1>
    <p>
      A growing collection of technical projects, from applied analytics workflows to model
      evaluation tools and software experiments.
    </p>
  </section>

  <section class="section">
    <ProjectGrid projects={sortedProjects} />
  </section>
</BaseLayout>
